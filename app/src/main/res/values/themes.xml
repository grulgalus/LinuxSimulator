<resources>
    <style name="Theme.LinuxSimulator" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">#50FA7B</item>
        <item name="colorPrimaryVariant">#3DBA5C</item>
        <item name="colorOnPrimary">#0D1117</item>
        <item name="colorSecondary">#8BE9FD</item>
        <item name="colorOnSecondary">#0D1117</item>
        <item name="android:windowBackground">#0D1117</item>
        <item name="android:statusBarColor">#161B22</item>
